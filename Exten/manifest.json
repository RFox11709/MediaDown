{
  "manifest_version": 3,
  "name": "MediaVal",
  "version": "3.0",
  "description": "Download media, files, and more from any page",
  "action": {
    "default_title": "Toggle MediaVal"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "permissions": ["activeTab"],
  "host_permissions": ["http://127.0.0.1:8000/*"]
}