{
  "manifest_version": 3,
  "name": "MediaVal",
  "version": "2.0",
  "action": {
    "default_title": "Toggle Downloader"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "permissions": ["activeTab"],
  "host_permissions": ["http://127.0.0.1:8000/*"]
}